---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Olle Rönn | Portfolio">
  <section class="hero home-hero">
    <div class="hero-content">
      <p class="eyebrow">Portfolio · Projekt · Lärande</p>

      <h1>
        Olle Rönn
        <span class="hero-line text-glow">IT, säkerhet och infrastruktur.</span>
      </h1>

      <p class="hero-subtitle">
        IT-ingenjörsstudent med praktisk erfarenhet av IAM, Active Directory,
        Entra ID, Azure och PowerShell.
      </p>

      <p class="lead">
        Här samlar jag projekt, tekniska färdigheter och dokumenterat lärande
        inom cybersäkerhet, IT-infrastruktur, cloud, Linux, nätverk och
        systemnära teknik.
      </p>

      <div class="buttons">
        <a class="button" href="/projects">Se projekt</a>
        <a class="button secondary" href="/cv">Se CV</a>
        <a class="button secondary" href="/learning-log">Lärandelogg</a>
        <a class="button secondary" href="/contact">Kontakt</a>
      </div>
    </div>

    <aside class="hero-card">
      <p class="hero-card-label">Aktuellt projekt</p>
      <h2>Secure Homelab</h2>

      <p>
        Jag bygger just nu en säker och dokumenterad servermiljö med Ubuntu Server,
        VirtualBox, SSH, Linux och teknisk dokumentation.
      </p>

      <div class="status-row">
        <span>Status</span>
        <strong>Aktiv</strong>
      </div>

      <div class="mini-list">
        <span>Ubuntu Server</span>
        <span>SSH</span>
        <span>VirtualBox</span>
        <span>Linux</span>
        <span>GitHub Docs</span>
      </div>
    </aside>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">Snabb överblick</p>
      <h2>Kort överblick</h2>
      <p>
        En snabb sammanfattning av min erfarenhet, mina projekt och de tekniska
        områden jag arbetar med.
      </p>
    </div>

    <div class="proof-grid">
      <article class="card">
        <span class="tag">Erfarenhet</span>
        <h3>IAM i företagsmiljö</h3>
        <p>
          Praktisk erfarenhet av Identity & Access Management, Active Directory,
          Entra ID, Azure och PowerShell från Stena Group IT.
        </p>
      </article>

      <article class="card">
        <span class="tag">Aktivt projekt</span>
        <h3>Secure Homelab</h3>
        <p>
          Ubuntu Server är installerad i VirtualBox, uppdaterad och nåbar via SSH
          från Windows med NAT port forwarding.
        </p>
      </article>

      <article class="card">
        <span class="tag">Systemutveckling</span>
        <h3>C# och WPF-projekt</h3>
        <p>
          Byggt ett sportklubbssystem med MVVM, flera lager, SQL Server,
          repositories och Unit of Work.
        </p>
      </article>

      <article class="card">
        <span class="tag">Dokumentation</span>
        <h3>GitHub och lärandelogg</h3>
        <p>
          Dokumenterar projekt, tekniska beslut, problem, lösningar och lärdomar
          steg för steg.
        </p>
      </article>
    </div>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">Utvalda projekt</p>
      <h2>Projekt med konkret resultat</h2>
      <p>
        Några av de viktigaste projekten just nu. Korten är klickbara och leder
        till respektive GitHub-repo.
      </p>
    </div>

    <div class="featured-projects">
      <a
        class="featured-project-card clickable-card"
        href="https://github.com/ollernn/secure-homelab"
        target="_blank"
        rel="noreferrer"
      >
        <div class="project-top">
          <span class="tag">Linux · Security Lab</span>
          <span class="project-status active">Aktiv</span>
        </div>

        <h3>Secure Homelab</h3>

        <p>
          Säker och dokumenterad servermiljö för Linux, SSH, nätverk,
          serverhärdning, Docker och teknisk dokumentation.
        </p>

        <p>
          <strong>Checkpoint:</strong> Ubuntu Server installerad, uppdaterad och
          nåbar via SSH från Windows.
        </p>

        <div class="tech-list">
          <span>Ubuntu Server</span>
          <span>VirtualBox</span>
          <span>SSH</span>
          <span>Linux</span>
          <span>NAT</span>
        </div>
      </a>

      <a
        class="featured-project-card clickable-card"
        href="https://github.com/ollernn/portfolio"
        target="_blank"
        rel="noreferrer"
      >
        <div class="project-top">
          <span class="tag">Astro · Portfolio</span>
          <span class="project-status live">Live</span>
        </div>

        <h3>Portfolio Website</h3>

        <p>
          Personlig portfolio byggd med Astro och publicerad med Vercel.
          Används för projekt, CV, lärandelogg och teknisk dokumentation.
        </p>

        <div class="tech-list">
          <span>Astro</span>
          <span>HTML</span>
          <span>CSS</span>
          <span>GitHub</span>
          <span>Vercel</span>
        </div>
      </a>

      <a
        class="featured-project-card clickable-card"
        href="https://github.com/ollernn/OOPC-VT25-Grupp-07"
        target="_blank"
        rel="noreferrer"
      >
        <div class="project-top">
          <span class="tag">C# · WPF · MVVM</span>
          <span class="project-status completed">Avslutat</span>
        </div>

        <h3>Sport Club Management System</h3>

        <p>
          Större skolprojekt med inloggning, roller, träningspass,
          medlemsfunktioner, utrustningshantering, databas och tydlig lagerstruktur.
        </p>

        <div class="tech-list">
          <span>C#</span>
          <span>WPF</span>
          <span>MVVM</span>
          <span>SQL Server</span>
          <span>Entity Framework</span>
        </div>
      </a>
    </div>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">Teknisk riktning</p>
      <h2>Områden jag fokuserar på</h2>
      <p>
        Mina projekt och min erfarenhet rör sig främst kring praktiska IT-miljöer,
        säkerhet och drift.
      </p>
    </div>

    <div class="focus-grid">
      <article class="focus-card">
        <span class="tag">Infrastructure</span>
        <h3>IT-infrastruktur</h3>
        <p>
          Servrar, nätverk, Windows-miljöer, Linux, grundläggande drift och
          strukturerade IT-miljöer.
        </p>
      </article>

      <article class="focus-card">
        <span class="tag">Security</span>
        <h3>Cybersäkerhet & IAM</h3>
        <p>
          Behörigheter, accessgranskning, Active Directory, Entra ID,
          säkerhetsgrunder och riskanalys.
        </p>
      </article>

      <article class="focus-card">
        <span class="tag">Cloud</span>
        <h3>Azure & cloud</h3>
        <p>
          Molntjänster, identitet, storage, logging, kostnadskontroll och
          säkra cloud-miljöer.
        </p>
      </article>

      <article class="focus-card">
        <span class="tag">Automation</span>
        <h3>Scripting & dokumentation</h3>
        <p>
          PowerShell, GitHub, teknisk dokumentation och automatisering av
          återkommande arbetsflöden.
        </p>
      </article>
    </div>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">Kort om mig</p>
      <h2>Lite mer om mig</h2>
      <p>
        Jag gillar att förstå hur tekniska system fungerar i praktiken. När jag
        lär mig något nytt vill jag testa det själv, bygga något av det och
        dokumentera vad jag gjorde, vad som fungerade och vad som kan förbättras.
      </p>
    </div>

    <div class="personal-grid">
      <article class="card">
        <h3>Teknikintresse</h3>
        <p>
          Jag är intresserad av IT-infrastruktur, cybersäkerhet, cloud,
          systemnära teknik och hårdvara.
        </p>
      </article>

      <article class="card">
        <h3>Utanför studier och projekt</h3>
        <p>
          På fritiden spelar jag golf, gymmar, spelar dator, reser gärna och är
          intresserad av datorhårdvara, tangentbord, möss och hur tekniska
          komponenter fungerar.
        </p>
      </article>
    </div>
  </section>

  <section class="cta-section">
    <div>
      <p class="eyebrow">Utforska mer</p>
      <h2>Vill du se mer?</h2>
      <p>
        Se projekten på GitHub, läs CV:t eller följ lärandeloggen där jag
        sammanfattar vad jag bygger och lär mig.
      </p>
    </div>

    <div class="buttons">
      <a class="button" href="/projects">Projekt</a>
      <a class="button secondary" href="/cv">CV</a>
      <a class="button secondary" href="/contact">Kontakt</a>
    </div>
  </section>
</MainLayout>

<style>
  .home-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(290px, 0.85fr);
    gap: 2rem;
    align-items: end;
  }

  .hero-content {
    max-width: 840px;
  }

  .hero-line {
    display: block;
  }

  .hero-subtitle {
    max-width: 760px;
    color: var(--text);
    font-size: clamp(1.15rem, 2vw, 1.38rem);
    line-height: 1.38;
    margin: 0 0 1rem;
  }

  .hero-card {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.018)),
      var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
  }

  .hero-card-label {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    margin: 0 0 0.75rem;
  }

  .hero-card h2 {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
  }

  .status-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    color: var(--muted);
  }

  .status-row strong {
    color: var(--accent);
  }

  .mini-list,
  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1rem;
  }

  .mini-list span,
  .tech-list span {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.28rem 0.58rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-soft);
    background: rgba(255, 255, 255, 0.025);
    font-size: 0.78rem;
    font-weight: 650;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .featured-projects {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .featured-project-card,
  .focus-card {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
      var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.35rem;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }

  .featured-project-card:hover,
  .focus-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-hover);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
      var(--surface-soft);
  }

  .clickable-card {
    display: block;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
  }

  .clickable-card h3 {
    transition: color 160ms ease;
  }

  .clickable-card:hover h3 {
    color: var(--accent);
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .project-status {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .project-status.live {
    background: rgba(34, 197, 94, 0.12);
    color: #86efac;
  }

  .project-status.active {
    background: rgba(147, 197, 253, 0.14);
    color: var(--accent);
  }

  .project-status.completed {
  background: rgba(148, 163, 184, 0.12);
  color: #cbd5e1;
}

.project-status.planned {
  background: rgba(168, 85, 247, 0.12);
  color: #d8b4fe;
}

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .focus-card p,
  .featured-project-card p {
    color: var(--muted);
  }

  .personal-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .cta-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.018)),
      var(--surface);
  }

  .cta-section h2 {
    margin-bottom: 0.75rem;
  }

  .cta-section p {
    max-width: 680px;
    color: var(--muted);
  }

  .cta-section .buttons {
    margin-top: 0;
    flex-shrink: 0;
  }

  code {
    color: var(--accent);
    background: rgba(147, 197, 253, 0.08);
    border: 1px solid rgba(147, 197, 253, 0.14);
    padding: 0.08rem 0.28rem;
    border-radius: 0.35rem;
    font-size: 0.9em;
  }

  @media (max-width: 1050px) {
    .proof-grid,
    .focus-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .featured-projects {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 860px) {
    .home-hero {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .cta-section {
      flex-direction: column;
      align-items: flex-start;
    }

    .cta-section .buttons {
      width: 100%;
    }

    .personal-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .proof-grid,
    .focus-grid {
      grid-template-columns: 1fr;
    }

    .project-top {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
