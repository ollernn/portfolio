---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Olle Rönn | Portfolio">
  <section class="hero home-hero">
    <div class="hero-content">
      <p class="eyebrow">Portfolio · Projects · Learning</p>

      <h1>
        Olle Rönn
        <span class="hero-line text-glow">IT, security and infrastructure.</span>
      </h1>

      <p class="hero-subtitle">
        IT engineering student with practical experience in IAM, Active Directory,
        Entra ID, Azure and PowerShell.
      </p>

      <p class="lead">
        This portfolio presents my projects, technical skills and documented
        learning within cybersecurity, IT infrastructure, cloud, Linux, networking
        and systems engineering.
      </p>

      <div class="buttons">
        <a class="button" href="/projects">View projects</a>
        <a class="button secondary" href="/cv">View CV</a>
        <a class="button secondary" href="/learning-log">Learning Log</a>
        <a class="button secondary" href="/contact">Contact</a>
      </div>
    </div>

    <a class="hero-card clickable-card" href="/projects">
  <p class="hero-card-label">Latest project</p>
  <h2>Cloud Homelab v2</h2>

  <p>
    I am building a secure hybrid cloud deployment that extends my local Secure
    Homelab v1 into Azure using FastAPI, Docker, Azure Container Registry,
    Azure Container Apps and GitHub Actions CI.
  </p>

  <div class="status-row">
    <span>Status</span>
    <strong>Azure deployment live</strong>
  </div>

  <div class="mini-list">
    <span>FastAPI</span>
    <span>Docker</span>
    <span>Azure</span>
    <span>GitHub Actions</span>
    <span>API Security</span>
  </div>
</a>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">Overview</p>
      <h2>Quick snapshot</h2>
      <p>
        A short summary of my experience, current projects and technical focus areas.
      </p>
    </div>

    <div class="proof-grid">
      <article class="card">
        <span class="tag">Experience</span>
        <h3>IAM in an enterprise environment</h3>
        <p>
          Practical experience with Identity & Access Management, Active Directory,
          Entra ID, Azure and PowerShell from Stena Group IT.
        </p>
      </article>

      <article class="card">
        <span class="tag">Completed v1</span>
        <h3>Secure Homelab</h3>
        <p>
          Built, secured and documented a Linux-based homelab with SSH hardening,
          firewall rules, fail2ban, Docker services and monitoring.
        </p>
      </article>

      <article class="card">
        <span class="tag">Software project</span>
        <h3>C# and WPF application</h3>
        <p>
          Built a sport club management system using MVVM, layered architecture,
          SQL Server, repositories and Unit of Work.
        </p>
      </article>

      <article class="card">
        <span class="tag">Documentation</span>
        <h3>GitHub and learning log</h3>
        <p>
          I document projects, technical decisions, problems, solutions and lessons
          learned step by step.
        </p>
      </article>
    </div>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">Featured projects</p>
      <h2>Projects with concrete results</h2>
      <p>
        A few selected projects. The cards are clickable and open the related
        GitHub repositories.
      </p>
    </div>

    <div class="featured-projects">
  <a
    class="featured-project-card clickable-card"
    href="https://github.com/ollernn/cloud-homelab-v2"
    target="_blank"
    rel="noreferrer"
  >
    <div class="project-top">
      <span class="tag">FastAPI · Docker · Azure</span>
      <span class="project-status active">In Progress</span>
    </div>

    <h3>Cloud Homelab v2</h3>

    <p>
      A secure hybrid cloud project where I containerized a FastAPI application,
      added API key protection, automated tests and deployed it to Azure Container Apps.
    </p>

    <p>
      <strong>Current result:</strong> Azure deployment is live and GitHub Actions CI is passing.
    </p>

    <div class="tech-list">
      <span>FastAPI</span>
      <span>Docker</span>
      <span>Azure</span>
      <span>ACR</span>
      <span>Container Apps</span>
      <span>GitHub Actions</span>
    </div>
  </a>

  <a
    class="featured-project-card clickable-card"
    href="https://github.com/ollernn/secure-homelab"
    target="_blank"
    rel="noreferrer"
  >
    <div class="project-top">
      <span class="tag">Linux · Security Lab</span>
      <span class="project-status completed">v1 Complete</span>
    </div>

    <h3>Secure Homelab</h3>

    <p>
      A practical infrastructure and cybersecurity project where I built, secured
      and documented a small Linux-based server environment.
    </p>

    <p>
      <strong>Result:</strong> Ubuntu Server, SSH hardening, UFW, fail2ban,
      Docker services, monitoring and documentation are in place.
    </p>

    <div class="tech-list">
      <span>Ubuntu Server</span>
      <span>VirtualBox</span>
      <span>SSH</span>
      <span>UFW</span>
      <span>Docker</span>
      <span>Monitoring</span>
    </div>
  </a>

  <a
    class="featured-project-card clickable-card"
    href="https://github.com/ollernn/portfolio"
    target="_blank"
    rel="noreferrer"
  >
    <div class="project-top">
      <span class="tag">Astro · Portfolio</span>
      <span class="project-status live">Live</span>
    </div>

    <h3>Portfolio Website</h3>

    <p>
      A personal portfolio built with Astro and deployed with Vercel.
      It is used to present projects, my CV, learning logs and technical work.
    </p>

    <div class="tech-list">
      <span>Astro</span>
      <span>HTML</span>
      <span>CSS</span>
      <span>GitHub</span>
      <span>Vercel</span>
    </div>
  </a>

  <a
    class="featured-project-card clickable-card"
    href="https://github.com/ollernn/OOPC-VT25-Grupp-07"
    target="_blank"
    rel="noreferrer"
  >
    <div class="project-top">
      <span class="tag">C# · WPF · MVVM</span>
      <span class="project-status completed">Completed</span>
    </div>

    <h3>Sport Club Management System</h3>

    <p>
      A larger university project with login, roles, training sessions,
      member features, equipment management, database access and layered architecture.
    </p>

    <div class="tech-list">
      <span>C#</span>
      <span>WPF</span>
      <span>MVVM</span>
      <span>SQL Server</span>
      <span>Entity Framework</span>
    </div>
  </a>
</div>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">Technical focus</p>
      <h2>Areas I focus on</h2>
      <p>
        My projects and experience are mainly centered around practical IT
        environments, security, operations and documentation.
      </p>
    </div>

    <div class="focus-grid">
      <article class="focus-card">
        <span class="tag">Infrastructure</span>
        <h3>IT Infrastructure</h3>
        <p>
          Servers, networking, Windows environments, Linux, basic operations and
          structured IT environments.
        </p>
      </article>

      <article class="focus-card">
        <span class="tag">Security</span>
        <h3>Cybersecurity & IAM</h3>
        <p>
          Permissions, access reviews, Active Directory, Entra ID, security
          fundamentals and risk awareness.
        </p>
      </article>

      <article class="focus-card">
        <span class="tag">Cloud</span>
        <h3>Azure & Cloud</h3>
        <p>
          Cloud services, identity, storage, logging, cost awareness and secure
          cloud environments.
        </p>
      </article>

      <article class="focus-card">
        <span class="tag">Automation</span>
        <h3>Scripting & Documentation</h3>
        <p>
          PowerShell, GitHub, technical documentation and automation of recurring
          workflows.
        </p>
      </article>
    </div>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">About</p>
      <h2>A bit more about me</h2>
      <p>
        I like understanding how technical systems work in practice. When I learn
        something new, I prefer to test it myself, build something from it and
        document what I did and learned.
      </p>
    </div>

    <div class="personal-grid">
      <article class="card">
        <h3>Technical interests</h3>
        <p>
          I am interested in IT infrastructure, cybersecurity, cloud, systems
          engineering and hardware.
        </p>
      </article>

      <article class="card">
        <h3>Outside studies and projects</h3>
        <p>
          Outside of studies and projects, I play golf, go to the gym, play games,
          enjoy travelling and have an interest in computer hardware, keyboards,
          mice and how technical components work.
        </p>
      </article>
    </div>
  </section>

  <section class="cta-section">
    <div>
      <p class="eyebrow">Explore more</p>
      <h2>Want to see more?</h2>
      <p>
        View my projects on GitHub, read my CV or follow the learning log where
        I summarize what I build and learn.
      </p>
    </div>

    <div class="buttons">
      <a class="button" href="/projects">Projects</a>
      <a class="button secondary" href="/cv">CV</a>
      <a class="button secondary" href="/contact">Contact</a>
    </div>
  </section>
</MainLayout>

<style>
  .home-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(290px, 0.85fr);
    gap: 2rem;
    align-items: end;
  }

  .hero-content {
    max-width: 840px;
  }

  .hero-line {
    display: block;
  }

  .hero-subtitle {
    max-width: 760px;
    color: var(--text);
    font-size: clamp(1.15rem, 2vw, 1.38rem);
    line-height: 1.38;
    margin: 0 0 1rem;
  }

  .hero-card {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.018)),
      var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
  }

  .hero-card.clickable-card {
  display: block;
  color: inherit;
  text-decoration: none;
  cursor: pointer;
  transition:
    transform 160ms ease,
    border-color 160ms ease,
    background 160ms ease,
    box-shadow 160ms ease;
}

.hero-card.clickable-card:hover {
  transform: translateY(-3px);
  border-color: var(--border-hover);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.065), rgba(255, 255, 255, 0.026)),
    var(--surface-soft);
  box-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
}

.hero-card.clickable-card:hover h2 {
  color: var(--accent);
}

  .hero-card-label {
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    margin: 0 0 0.75rem;
  }

  .hero-card h2 {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
  }

  .hero-card p {
    color: var(--muted);
  }

  .status-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    color: var(--muted);
  }

  .status-row strong {
    color: var(--accent);
  }

  .mini-list,
  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1rem;
  }

  .mini-list span,
  .tech-list span {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.28rem 0.58rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-soft);
    background: rgba(255, 255, 255, 0.025);
    font-size: 0.78rem;
    font-weight: 650;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .featured-projects {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1rem;
  margin-top: 1.5rem;
  align-items: start;
}

  .featured-project-card,
  .focus-card {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
      var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.35rem;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }

  .featured-project-card:hover,
  .focus-card:hover,
  .hero-card.clickable-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-hover);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
      var(--surface-soft);
  }

  .clickable-card {
    display: block;
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }

  .clickable-card h3,
  .clickable-card h2 {
    transition: color 160ms ease;
  }

  .clickable-card:hover h3,
  .clickable-card:hover h2 {
    color: var(--accent);
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .project-status {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .project-status.live {
    background: rgba(34, 197, 94, 0.12);
    color: #86efac;
  }

  .project-status.active {
    background: rgba(147, 197, 253, 0.14);
    color: var(--accent);
  }

  .project-status.completed {
    background: rgba(148, 163, 184, 0.12);
    color: #cbd5e1;
  }

  .project-status.planned {
    background: rgba(168, 85, 247, 0.12);
    color: #d8b4fe;
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .focus-card p,
  .featured-project-card p {
    color: var(--muted);
  }

  .personal-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .cta-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.018)),
      var(--surface);
  }

  .cta-section h2 {
    margin-bottom: 0.75rem;
  }

  .cta-section p {
    max-width: 680px;
    color: var(--muted);
  }

  .cta-section .buttons {
    margin-top: 0;
    flex-shrink: 0;
  }

  code {
    color: var(--accent);
    background: rgba(147, 197, 253, 0.08);
    border: 1px solid rgba(147, 197, 253, 0.14);
    padding: 0.08rem 0.28rem;
    border-radius: 0.35rem;
    font-size: 0.9em;
  }

  @media (max-width: 1200px) {
  .featured-projects {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 1050px) {
  .proof-grid,
  .focus-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

  @media (max-width: 860px) {
    .home-hero {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .cta-section {
      flex-direction: column;
      align-items: flex-start;
    }

    .cta-section .buttons {
      width: 100%;
    }

    .personal-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
  .proof-grid,
  .focus-grid,
  .featured-projects {
    grid-template-columns: 1fr;
  }

  .project-top {
    flex-direction: column;
    gap: 0.5rem;
  }
}
</style>
