---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Olle Rönn | Contact">
  <section class="hero contact-hero">
    <p class="eyebrow">Contact</p>

    <h1>Contact</h1>

    <p class="lead">
      Feel free to reach out about projects, part-time roles, internships, junior
      positions or opportunities within IT infrastructure, cloud, cybersecurity,
      IAM, automation and systems engineering.
    </p>
  </section>

  <section>
    <div class="contact-layout">
      <article class="card contact-card">
        <p class="eyebrow">Contact details</p>
        <h2>Get in touch</h2>

        <p>
          I am mainly interested in opportunities where I can work practically
          with IT, infrastructure, security, cloud, automation or technical system
          environments.
        </p>

        <div class="contact-details">
          <div>
            <span>Email</span>
            <a href="mailto:olle.d.ronn@gmail.com">olle.d.ronn@gmail.com</a>
          </div>

          <div>
            <span>Location</span>
            <p>Gothenburg, Sweden</p>
          </div>
        </div>
      </article>

      <aside class="card links-card">
        <p class="eyebrow">Links</p>
        <h2>Profiles</h2>

        <p>
          Here you can find my projects, professional profile and certifications.
        </p>

        <div class="profile-links">
          <a
            class="button secondary"
            href="https://github.com/ollernn"
            target="_blank"
            rel="noreferrer"
          >
            GitHub
          </a>

          <a
            class="button secondary"
            href="https://www.linkedin.com/in/olle-r%C3%B6nn-81822b278/"
            target="_blank"
            rel="noreferrer"
          >
            LinkedIn
          </a>

          <a
            class="button secondary"
            href="https://www.credly.com/users/olle-ronn"
            target="_blank"
            rel="noreferrer"
          >
            Credly
          </a>
        </div>
      </aside>
    </div>
  </section>
</MainLayout>

<style>
  .contact-hero h1 {
    font-size: clamp(2.4rem, 5.2vw, 4.2rem);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.8fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .contact-card h2,
  .links-card h2 {
    margin-bottom: 0.75rem;
  }

  .contact-details {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .contact-details div {
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .contact-details span {
    display: block;
    color: var(--accent);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .contact-details a {
    color: var(--text);
    font-weight: 750;
  }

  .contact-details a:hover {
    color: var(--accent);
  }

  .contact-details p {
    margin: 0;
    color: var(--text-soft);
  }

  .profile-links {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .profile-links .button {
    width: 100%;
  }

  @media (max-width: 860px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }
</style>