---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Olle Rönn | CV">
  <section class="hero cv-hero">
    <p class="eyebrow">CV</p>

    <h1>CV</h1>

    <p class="lead">
      IT-ingenjörsstudent med inriktning mot digital infrastruktur och cybersäkerhet.
      Jag har praktisk erfarenhet av Identity & Access Management, Active Directory,
      Entra ID, Azure och PowerShell-automatisering, samt en stark grund inom nätverk
      och cybersäkerhet.
    </p>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">Erfarenhet</p>
      <h2>Relevant erfarenhet</h2>
    </div>

    <div class="experience-list">
      <article class="card experience-card">
        <div class="experience-meta">
          <span class="tag">Nov 2025 – Jan 2026</span>
          <p>Göteborg</p>
        </div>

        <div>
          <h3>Stena Group IT</h3>
          <p class="role">Identity & Access Management</p>

          <p>
            Arbetade med IAM i en större företagsmiljö med hantering av användare,
            behörigheter och privilegierade konton i Active Directory, Entra ID och Azure.
          </p>

          <ul>
            <li>Utförde accessgranskningar och kontoanalyser.</li>
            <li>Analyserade säkerhetsrisker och attackmetoder i en verklig IT-miljö.</li>
            <li>Använde PowerShell för datainsamling, automatisering och processstöd.</li>
          </ul>
        </div>
      </article>

    </div>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">Utbildning</p>
      <h2>Utbildning</h2>
    </div>

    <div class="grid">
      <article class="card">
        <span class="tag">Aug 2026 – Jun 2028</span>
        <h3>Chalmers tekniska högskola</h3>
        <p class="role">Masterprogram i High Performance Computer Systems, 120 hp</p>
        <p>
          Fördjupning inom högpresterande datorsystem, parallell programmering,
          systemarkitektur och distribuerade system.
        </p>
      </article>

      <article class="card">
        <span class="tag">Aug 2023 – Jun 2026</span>
        <h3>Högskolan i Borås</h3>
        <p class="role">IT-ingenjör – Digital infrastruktur och cybersäkerhet, 180 hp</p>
        <p>
          Treårig ingenjörsutbildning med fokus på digital infrastruktur, nätverk,
          system och cybersäkerhet.
        </p>
      </article>

      <article class="card">
        <span class="tag">Aug 2019 – Jun 2022</span>
        <h3>Lindholmens Tekniska Gymnasium</h3>
        <p>
          Information och media med inriktning mot design, programmering och datorkunskap.
        </p>
      </article>
    </div>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">Teknik</p>
      <h2>Tekniska kunskaper</h2>
    </div>

    <div class="skills-grid">
      <article class="card">
        <h3>IT-infrastruktur & nätverk</h3>
        <ul>
          <li>Windows-miljöer och grundläggande systemadministration</li>
          <li>TCP/IP, routing och switching på CCNA-nivå</li>
          <li>Nätverksfelsökning och nätverksgrunder</li>
        </ul>
      </article>

      <article class="card">
        <h3>Identity & Access Management</h3>
        <ul>
          <li>Active Directory, Entra ID och Azure</li>
          <li>Användare, behörigheter och privilegierade konton</li>
          <li>Accessgranskningar och kontoanalyser</li>
        </ul>
      </article>

      <article class="card">
        <h3>Cybersäkerhet</h3>
        <ul>
          <li>Säkerhetsgrunder och analys av attackmetoder</li>
          <li>Nätverkstrafikanalys med Wireshark och PCAP</li>
          <li>Grundläggande säkerhetsövervakning och incidenthantering</li>
        </ul>
      </article>

      <article class="card">
        <h3>Scripting & automation</h3>
        <ul>
          <li>PowerShell för administration, automatisering och datainsamling</li>
          <li>Grundläggande Python</li>
          <li>Grundläggande SQL</li>
        </ul>
      </article>

      <article class="card">
        <h3>Verktyg & teknologier</h3>
        <ul>
          <li>Azure och grundläggande molntjänster</li>
          <li>Wireshark, Kali Linux och CyberChef</li>
          <li>GitHub och teknisk dokumentation</li>
        </ul>
      </article>

      <article class="card">
        <h3>Standarder & ramverk</h3>
        <ul>
          <li>Grundläggande förståelse för NIS2</li>
          <li>Grundläggande förståelse för ISO/IEC 27001</li>
        </ul>
      </article>
    </div>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">Certifikat & kurser</p>
      <h2>Certifikat och relevanta kurser</h2>
    </div>

    <div class="cv-two-column">
      <article class="card">
        <h3>Certifikat</h3>

        <ul>
          <li>Cisco IT Essentials</li>
          <li>Cisco Introduction to Cybersecurity</li>
          <li>Cisco Cybersecurity Essentials</li>
          <li>Cisco CCNA: ITN, SRWE och ENSA</li>
          <li>Cisco Ethical Hacker</li>
          <li>Cisco CyberOps Associate</li>
        </ul>
      </article>

      <article class="card">
        <h3>Relevanta kurser</h3>

        <p>
          Nätverk, operativsystem, serversystem och infrastruktur, databaser och
          dataanalys, IoT och molntjänster, cybersäkerhet för uppkopplade enheter,
          Python-programmering, projektledning, teknisk rapportering, taktisk
          cybersäkerhet och incidenthantering.
        </p>
      </article>
    </div>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">Övrigt</p>
      <h2>Övrig erfarenhet</h2>
    </div>

    <div class="grid">
      <article class="card">
        <span class="tag">Sep 2024 – Nuvarande</span>
        <h3>OnePartnerGroup</h3>
        <p>
          Lagerarbete inklusive truckkörning, godshantering och förberedelse av leveranser.
        </p>
      </article>

      <article class="card">
        <span class="tag">Apr 2023 – Nuvarande</span>
        <h3>Göteborgs Stad</h3>
        <p>
          Stöd till ungdomar i strukturerade dagliga aktiviteter med fokus på digitalt engagemang.
        </p>
      </article>

      <article class="card">
        <span class="tag">Maj 2022 – Jun 2023</span>
        <h3>Bauhaus</h3>
        <p>
          Säljare inom bygg och VVS samt godshantering med truck och lyftutrustning.
        </p>
      </article>
    </div>
  </section>

  <section>
    <div class="section-heading">
      <p class="eyebrow">Språk & behörigheter</p>
      <h2>Språk och behörigheter</h2>
    </div>

    <div class="cv-two-column">
      <article class="card">
        <h3>Språk</h3>
        <ul>
          <li>Svenska – modersmål</li>
          <li>Engelska – flytande i tal och skrift</li>
        </ul>
      </article>

      <article class="card">
        <h3>Körkort & behörigheter</h3>
        <ul>
          <li>Körkort B</li>
          <li>Truckkort A1–A4, B1–B3</li>
        </ul>
      </article>
    </div>
  </section>
</MainLayout>

<style>
  .cv-hero h1 {
    font-size: clamp(2.4rem, 5.2vw, 4.2rem);
  }

  .experience-list {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .experience-card {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 1.5rem;
  }

  .experience-meta p {
    color: var(--muted);
    margin-top: 0.5rem;
  }

  .role {
    color: var(--accent);
    font-weight: 700;
    margin-top: -0.25rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .cv-two-column {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  ul {
    margin: 0.75rem 0 0;
    padding-left: 1.2rem;
    color: var(--text-soft);
  }

  li {
    margin-bottom: 0.45rem;
  }

  li::marker {
    color: var(--accent);
  }

  @media (max-width: 860px) {
    .experience-card {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .skills-grid,
    .cv-two-column {
      grid-template-columns: 1fr;
    }
  }
</style>
