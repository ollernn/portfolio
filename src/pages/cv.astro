---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="CV | Olle Rönn">
  <h1>CV</h1>

  <div class="grid">
    <section class="card">
      <h3>Utbildning</h3>
      <p>IT-ingenjör med inriktning mot cybersäkerhet och digital infrastruktur.</p>
    </section>

    <section class="card">
      <h3>Tekniska områden</h3>
      <p>Linux, nätverk, GitHub, cloud, säkerhet, infrastruktur, automation och webbutveckling.</p>
    </section>

    <section class="card">
      <h3>Erfarenhet</h3>
      <p>Här kommer arbetslivserfarenhet, projekt och relevanta roller att fyllas på.</p>
    </section>
  </div>
</MainLayout>
